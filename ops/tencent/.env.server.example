# MedRoundTable backend
HOST=127.0.0.1
PORT=8000
DEBUG=false
SECRET_KEY=replace-with-a-long-random-string
DATABASE_URL=sqlite:////opt/medroundtable/data/medroundtable.db
MRT_UPLOAD_DIR=/opt/medroundtable/data/uploads
MEDROUNDTABLE_UPLOAD_DIR=/opt/medroundtable/data/uploads
ALLOWED_ORIGINS=https://mokangmedical.github.io,https://medroundtable.vip,https://www.medroundtable.vip

# Kimi / Moonshot
MOONSHOT_API_KEY=replace-with-your-real-key
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=moonshot/kimi-k2-0905-preview
MOONSHOT_TIMEOUT=12
MOONSHOT_PREFER_DISCUSSION_MOCK=false

# SecondMe
SECONDME_CLIENT_ID=replace-with-your-client-id
SECONDME_CLIENT_SECRET=replace-with-your-client-secret
SECONDME_REDIRECT_URI=https://api.medroundtable.vip/api/auth/callback
SECONDME_API_BASE=https://api.mindverse.com/gate/lab
