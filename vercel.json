{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": null,
  "installCommand": "",
  "buildCommand": "",
  "outputDirectory": ".",
  "public": true,
  "cleanUrls": false,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api?__path=:path*"
    },
    {
      "source": "/health",
      "destination": "/api?__path=health"
    }
  ],
  "functions": {
    "api/[...path].py": {
      "maxDuration": 60,
      "excludeFiles": "{.git/**,.venv/**,docs/**,tmp/**,output/**,node_modules/**,frontend-new/**,**/__pycache__/**,**/*.pyc,**/*.pyo,**/*.db}"
    },
    "api/index.py": {
      "maxDuration": 60,
      "excludeFiles": "{.git/**,.venv/**,docs/**,tmp/**,output/**,node_modules/**,frontend-new/**,**/__pycache__/**,**/*.pyc,**/*.pyo,**/*.db}"
    }
  }
}
