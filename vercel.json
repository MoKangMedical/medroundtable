{
  "version": 2,
  "public": true,
  "github": {
    "enabled": true,
    "silent": true
  },
  "builds": [
    {
      "src": "frontend/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/api/(.*)",
      "dest": "https://medroundtable-api.onrender.com/api/$1"
    },
    {
      "src": "/roundtables/([0-9]+)",
      "dest": "/frontend/roundtables/detail.html"
    },
    {
      "src": "/roundtables/?$",
      "dest": "/frontend/roundtables/index.html"
    },
    {
      "src": "/tools",
      "dest": "/frontend/tools.html"
    },
    {
      "src": "/login",
      "dest": "/frontend/login-v2.html"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/index.html"
    }
  ]
}
